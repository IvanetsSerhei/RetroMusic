@model RetroMusicSite.WebUI.Models.Identity.CreateModel

@{
    ViewBag.Title = "Создание пользователя";
    Layout = "~/Views/Shared/_LayoutAdminka.cshtml";
}

@Html.ValidationSummary(false)
@using (Html.BeginForm())
{
    <div class="form-group">
        <label>Имя</label>
        @Html.TextBoxFor(x => x.Name, new { @class = "form-control" })
    </div>
    <div class="form-group">
        <label>Email</label>
        @Html.TextBoxFor(x => x.Email, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Пароль</label>
        @Html.PasswordFor(x => x.Password, new {@class = "form-control"})
    </div>

    <div class="form-group">
        <label>Пароль</label>
        @Html.PasswordFor(x => x.ConfirmPassword, new {@class = "form-control"})
    </div>
    
    <div class="form-group">
        <label >
            <img src="@Url.Action("Captcha", "Admin")" alt="captcha" />
        </label>
        <div class="controls">
            @Html.ValidationMessage("Captcha")
            @Html.TextBoxFor(x => x.Captcha, new { @class = "form-control" })
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Создать</button>

    @Html.ActionLink("Отмена", "Index", null, new { @class = "btn btn-default" })
}